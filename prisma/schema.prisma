generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================
// AUTH & USER
// ============================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  firstName     String?   @map("first_name")
  lastName      String?   @map("last_name")
  password      String?
  avatar        String?
  website       String?
  emailVerified DateTime? @map("email_verified")
  theme         String    @default("light") // "light" | "dark"
  language      String    @default("en")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  books         Book[]
  themes        Theme[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ============================
// BOOK & CHAPTERS
// ============================

model Book {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  subtitle    String?
  author      String?
  language    String   @default("en")
  coverUrl    String?  @map("cover_url")
  project     String?
  version     String?
  startPage   String   @default("title_page") @map("start_page")
  wordCount   Int      @default(0) @map("word_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Publisher details
  publisherName String? @map("publisher_name")
  publisherLink String? @map("publisher_link")
  printIsbn     String? @map("print_isbn")
  ebookIsbn     String? @map("ebook_isbn")
  publisherLogo String? @map("publisher_logo")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapters   Chapter[]
  themeId    String?    @map("theme_id")
  theme      Theme?     @relation(fields: [themeId], references: [id])
  snapshots  Snapshot[]

  @@index([userId])
  @@map("books")
}

model Chapter {
  id          String   @id @default(cuid())
  bookId      String   @map("book_id")
  title       String
  subtitle    String?
  type        String   @default("chapter") // front_matter | chapter | back_matter
  subtype     String?  // title_page, copyright, contents, about_author, etc.
  content     Json?    // TipTap JSON content
  order       Int
  imageUrl    String?  @map("image_url")
  wordCount   Int      @default(0) @map("word_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Per-chapter settings
  showChapterHeading  Boolean @default(true) @map("show_chapter_heading")
  showChapterImage    Boolean @default(false) @map("show_chapter_image")
  showPageNumbers     Boolean @default(true) @map("show_page_numbers")
  showHeaderFooter    Boolean @default(true) @map("show_header_footer")
  showInToc           Boolean @default(true) @map("show_in_toc")
  firstSentenceFormat Boolean @default(true) @map("first_sentence_format")
  useSmallerTitle     Boolean @default(false) @map("use_smaller_title")
  invertTextColor     Boolean @default(false) @map("invert_text_color")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@map("chapters")
}

// ============================
// THEMES & FORMATTING
// ============================

model Theme {
  id          String   @id @default(cuid())
  name        String
  userId      String?  @map("user_id")
  isBuiltIn   Boolean  @default(false) @map("is_built_in")
  isFavorite  Boolean  @default(false) @map("is_favorite")
  config      Json     // ThemeConfig JSON
  thumbnail   String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  books Book[]

  @@index([userId])
  @@map("themes")
}

// ============================
// SNAPSHOTS (VERSION CONTROL)
// ============================

model Snapshot {
  id        String   @id @default(cuid())
  bookId    String   @map("book_id")
  data      Json     // Full book + chapters snapshot
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@map("snapshots")
}
